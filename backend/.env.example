# ============================================
# LIDA FASHION WEAR — Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# Server
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/lida-fashion-wear?retryWrites=true&w=majority

# JWT Secrets (use strong random strings in production)
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_ADMIN_SECRET=your_super_secret_admin_jwt_key_change_this

# JWT Expiry
JWT_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=1d

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Node Environment
NODE_ENV=development
